NODE_ENV=development
PORT=3000

# Required for the backend API.
SUPABASE_URL=https://your-project.supabase.co

# Use the anon key for read-only demo access.
# Use the service role key if you want create/update workflows such as appointment management.
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Kept for project completeness and future backend expansion.
MONGODB_ATLAS_URI=

# CORS: comma-separated list of allowed origins.
# Only set this when the frontend is served from a different origin than the API.
# Leave empty (default) when the frontend is served by this Express server.
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGIN=

# Rate limiting: max requests per IP address per time window.
# Defaults: 120 requests per 60000 ms (1 minute).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
